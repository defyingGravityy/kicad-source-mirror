xbe name=pole_real_order_2 integrate=yes
+  allow_elex=yes elex_need_oldvars=yes
#
#           a
# y = ------------ x
#     (s-alpha)**2
#
Jacobian: constant
input_vars: x
output_vars: y
aux_vars: z1
aux_vars_ac:
iparms:
sparms:
rparms: a=1  alpha=1
stparms: y_st=0 z1_st=0
igparms:
outparms:
outparms_ac:
n_f= 2
f_1: d_dt(y)
f_2: d_dt(z1)
n_g= 2
g_1: z1 y
g_2: z1 x
n_f_ac=0
C:
endC
endxbe
