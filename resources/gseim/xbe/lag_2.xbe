xbe name=lag_2 integrate=yes
# This is used to create a "lag".
# d_dt(y)=(1.0/tr)*(-y+x)
# tr is computed s.t., at t=t_delay, y=v_high/2 (assuming
# a step from 0 to v_high is applied)
#
Jacobian: constant
input_vars: x
output_vars: y
aux_vars:
aux_vars_ac:
iparms:
sparms:
rparms:
+  t_delay=1
+  k=1
stparms: y_st=0
igparms: y_ig=0
outparms: x y
outparms_ac:
n_f= 1
f_1: d_dt(y)
n_g= 1
g_1: x y
n_f_ac=0
C:
endC
endxbe
