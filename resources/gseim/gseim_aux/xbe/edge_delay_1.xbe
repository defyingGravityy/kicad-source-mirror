xbe name=edge_delay_1 evaluate=yes limit_tstep=yes save_history=yes allow_ssw=no
#
# When a positive edge at x is detected, y is made to change
# from low to high after the specified delay (t_delay).
#
Jacobian: variable
input_vars: x
output_vars: y
aux_vars:
aux_vars_ac:
iparms:
sparms:
rparms:
+  x_high=1
+  t_delay=10u
+  t_rise=0.01m
+  x_prev=0
+  x_cross=0
+  t2=0
+  epsl1=0
stparms:
igparms:
outparms: x y
outparms_ac:
n_f= 0
n_g= 1
g_1: y
n_f_ac=0
C:
endC
endxbe
