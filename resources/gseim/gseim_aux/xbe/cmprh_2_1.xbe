xbe name=cmprh_2_1 evaluate=yes limit_tstep=yes save_history=yes elex_cmpr=yes
+  el3_cmpr=yes
# if x1-x2 > x0 +/- h/2, y = high, else low
# (reverse if flag_inverting=1)
# h is the hysterisis band, centred around x0
Jacobian: variable
input_vars: x1 x2
output_vars: y
aux_vars:
aux_vars_ac:
iparms:
+  flag_invert=0
+  flag_quad=0
sparms:
rparms:
+  x0=0
+  y_low=0
+  y_high=1
+  h=0.1
+  x1_1=0
+  x1_2=0
+  x2_1=0
+  x2_2=0
+  t_1=0
+  t_2=0
+  epsl=1.0e-6
+  delt_min=1.0e-6
+  delt_nrml=0.001
+  hby2=0
+  y_old=0
+  y_half=0
stparms:
igparms:
outparms: x1 x2 y
outparms_ac:
n_f= 0
n_g= 1
g_1: y
n_f_ac=0
C:
endC
endxbe
