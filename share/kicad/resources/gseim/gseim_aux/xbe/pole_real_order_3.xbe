xbe name=pole_real_order_3 integrate=yes
+  allow_elex=yes elex_need_oldvars=yes
#
#           a
# y = ------------ x
#     (s-alpha)**3
#
Jacobian: constant
input_vars: x
output_vars: y
aux_vars: z1 z2
aux_vars_ac:
iparms:
sparms:
rparms: a=1  alpha=1
stparms: y_st=0 z1_st=0 z2_st=0
igparms:
outparms:
outparms_ac:
n_f= 3
f_1: d_dt(y)
f_2: d_dt(z1)
f_3: d_dt(z2)
n_g= 3
g_1: y z1
g_2: z1 z2
g_3: z2 x
n_f_ac=0
C:
endC
endxbe
