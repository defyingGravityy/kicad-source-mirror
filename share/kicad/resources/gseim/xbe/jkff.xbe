xbe name=jkff evaluate=yes limit_tstep=yes save_history=yes allow_ssw=no
#
# JK flip-flop
#
Jacobian: variable
input_vars: clk j k
output_vars: q qbar
aux_vars:
aux_vars_ac:
iparms:
+  active_pos_edge=1
+  active_neg_edge=0
sparms:
rparms:
+  x_high=1
+  dt=0.1u
+  clk_prev=0
+  j_prev=0
+  k_prev=0
+  q_next=0
+  x_cross=0
stparms: q_st=0
igparms:
outparms: clk j k q
outparms_ac:
n_f= 0
n_g= 2
g_1: q
g_2: qbar
n_f_ac=0
C:
endC
endxbe
