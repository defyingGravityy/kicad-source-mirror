xbe name=pole_real_order_5 integrate=yes
+  allow_elex=yes elex_need_oldvars=yes
#
#           a
# y = ------------ x
#     (s-alpha)**5
#
Jacobian: constant
input_vars: x
output_vars: y
aux_vars: z1 z2 z3 z4
aux_vars_ac:
iparms:
sparms:
rparms: a=1  alpha=1
stparms: y_st=0 z1_st=0 z2_st=0 z3_st=0 z4_st=0
igparms:
outparms:
outparms_ac:
n_f= 5
f_1: d_dt(y)
f_2: d_dt(z1)
f_3: d_dt(z2)
f_4: d_dt(z3)
f_5: d_dt(z4)
n_g= 5
g_1: y z1
g_2: z1 z2
g_3: z2 z3
g_4: z3 z4
g_5: z4 x
n_f_ac=0
C:
endC
endxbe
