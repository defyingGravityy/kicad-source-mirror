xbe name=linear evaluate=yes
#
# (a1/a2)*y = (b1/b2)*x + (c1/c2)
#
Jacobian: constant
input_vars: x
output_vars: y
aux_vars:
aux_vars_ac:
iparms:
sparms:
rparms:
+  a1=1
+  a2=1
+  b1=1
+  b2=1
+  c1=0
+  c2=1
+  a=0
+  b=0
+  c=0
stparms:
igparms:
outparms: x y
outparms_ac:
n_f= 0
n_g= 1
g_1: x y
# (a1/a2)*y = (b1/b2)*x + (c1/c2)
# write as
# a*y = b*x + c
n_f_ac=0
C:
endC
endxbe
